# --- AI provider (OpenRouter or NVIDIA NIM, OpenAI-compatible) ---
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=sk-or-v1-...
AI_MODEL=openrouter/free

# --- Embeddings (FastEmbed local ONNX, no GPU, no API cost) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Qdrant Cloud ---
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=

# --- Supabase Auth ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=
ALLOWED_EMAIL=you@example.com

# --- LangSmith (tracing for the /ask graph + eval harness backbone) ---
# Read directly by the langsmith SDK, not through config.py — see CLAUDE.md.
# Leave LANGSMITH_TRACING=false (or unset) to run with no tracing / no LangSmith account.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=grounded-qa
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
